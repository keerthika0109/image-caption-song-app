# ============================================
# ENVIRONMENT VARIABLES - FRONTEND
# ============================================
# STEP TO USE: copy this file and rename the copy to ".env"
#   (Linux/Mac)   cp .env.example .env
#   (Windows)     copy .env.example .env
#
# This tells the React app where your backend server is running.
# For local development, the default (http://localhost:5000) is correct
# as long as you haven't changed PORT in the backend's .env file.

REACT_APP_API_URL=http://localhost:5000
