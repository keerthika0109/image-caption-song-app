# ============================================
# ENVIRONMENT VARIABLES - BACKEND
# ============================================
# STEP TO USE: copy this file and rename the copy to ".env"
#   (Linux/Mac)   cp .env.example .env
#   (Windows)     copy .env.example .env
#
# Then fill in your real keys below.
# NEVER commit the real ".env" file to GitHub or share it publicly.

# Port the backend server runs on
PORT=5000

# Google Gemini API key (FREE — for AI image captioning)
# Get it here: https://aistudio.google.com/app/apikey
#   1. Sign in with any Google account
#   2. Click "Create API key" — no credit card needed
#   3. Copy the key (starts with "AIza...")
GEMINI_API_KEY=your_gemini_api_key_here

# YouTube Data API v3 key (for fetching real song results)
# Get it here: https://console.cloud.google.com/
#   1. Create a project
#   2. Go to "APIs & Services" -> "Library" -> enable "YouTube Data API v3"
#   3. Go to "APIs & Services" -> "Credentials" -> "Create Credentials" -> "API key"
YOUTUBE_API_KEY=your_youtube_api_key_here

# Frontend origin allowed to call this backend (for CORS)
FRONTEND_URL=http://localhost:3000
